                flags | TextFormatFlags.VerticalCenter | TextFormatFlags.NoPadding | TextFormatFlags.NoPrefix);
        }

        protected override void OnMouseMove(MouseEventArgs e)
        {
            base.OnMouseMove(e);
            if (dragging)
            {
                Point screenPoint = PointToScreen(e.Location);
                Location = new Point(screenPoint.X - dragOrigin.X, screenPoint.Y - dragOrigin.Y);
                return;
            }
            string next = "";
            foreach (KeyValuePair<string, Rectangle> hit in hits)
                if (hit.Value.Contains(e.Location)) { next = hit.Key; break; }
            if (next != hover) { hover = next; Invalidate(); }
        }

        protected override void OnMouseDown(MouseEventArgs e)
        {
            base.OnMouseDown(e);
            if (e.Button != MouseButtons.Left) return;
            if (e.Y < 64 && !closeRect.Contains(e.Location) && !minRect.Contains(e.Location) && !langRect.Contains(e.Location))
            {
                dragging = true;
                dragOrigin = e.Location;
                return;
            }
            string action = "";
            foreach (KeyValuePair<string, Rectangle> hit in hits)
                if (hit.Value.Contains(e.Location)) { action = hit.Key; break; }
            HandleAction(action);
        }

        protected override void OnMouseUp(MouseEventArgs e)
        {
            dragging = false;
            base.OnMouseUp(e);
        }

        private void HandleAction(string action)
        {
            if (action == "close" || action == "cancel") { Close(); return; }
            if (action == "min") { WindowState = FormWindowState.Minimized; return; }
            if (action.StartsWith("lang"))
            {
                language = Int32.Parse(action.Substring(4));
                SaveLanguage();
                Invalidate();
                return;
            }
            if (action == "advanced") { screen = 1; Invalidate(); return; }
            if (action == "back") { screen = 0; Invalidate(); return; }
            if (action == "shortcut") { shortcut = !shortcut; Invalidate(); return; }
            if (action == "install") { StartInstall(false); return; }
            if (action == "cancelDownload") { CancelInstall(); return; }
            if (action == "openLog") { OpenLog(); return; }
            if (action == "details") { detailsOpen = !detailsOpen; Invalidate(); return; }
            if (action == "retry") { StartInstall(true); return; }
            if (action == "launch") { LaunchInstalled(); Close(); return; }
            if (action == "done") { Close(); return; }
        }

        private void StartInstall(bool cleanRetry)
        {
            if (config == null || installing) return;
            if (cleanRetry)
            {
                ReliableDownloader.SafeDelete(partPath);
                ReliableDownloader.SafeDelete(finalPath);
            }
            cancelled = false;
            installing = true;
            selectedInstallDir = installPathBox.Text.Trim();
            detailsOpen = false;
            technicalError = "";
            friendlyError = "";
            liveStatus = "prepare";
            progressValue = 0;
            progressBytes = 0;
            progressTotal = 0;
            logTail.Clear();
            AddUiLog(T("prepare"));
            screen = 2;
            Invalidate();

            downloader = new ReliableDownloader(config, logPath, OnDownloadProgress, OnDownloadStatus);
            worker = new Thread(InstallWorker);
            worker.IsBackground = true;
            worker.Start();
        }

        private void InstallWorker()
        {
            try
            {
                AppendLog(logPath, "Installation started.");
                liveStatus = "download";
                AddUiLog("Download started");
                DownloadResult result = downloader.Download(partPath, finalPath);
                AddUiLog("Download verified");

                liveStatus = "unpack";
                SafeInvalidate();
                AppendLog(logPath, "Starting installer: " + result.Path);
                ProcessStartInfo start = new ProcessStartInfo();
                start.FileName = result.Path;
                start.Arguments = "/S /D=" + selectedInstallDir;
                start.UseShellExecute = true;
                using (Process process = Process.Start(start))
                {
                    if (process == null) throw new InvalidOperationException("Failed to start the downloaded installer.");
                    while (!process.WaitForExit(250))
                    {
                        if (cancelled)
                        {
                            try { process.Kill(); } catch { }
                            throw new OperationCanceledException();
                        }
                    }
                    if (process.ExitCode != 0)
                        throw new InvalidOperationException("Installer exited with code " + process.ExitCode + ".");
                }

                if (shortcut) CreateShortcut(selectedInstallDir);
                liveStatus = "finish";
                AddUiLog(T("finish"));
                AppendLog(logPath, "Installation completed successfully.");
                installing = false;
                SafeUi(delegate { screen = 4; Invalidate(); });
            }
            catch (OperationCanceledException)
            {
                installing = false;
                AppendLog(logPath, "Installation cancelled by user.");
                ReliableDownloader.SafeDelete(partPath);
                SafeUi(delegate { screen = 0; Invalidate(); });
            }
            catch (Exception ex)
            {
                installing = false;
                technicalError = ex.ToString();
                friendlyError = ClassifyError(ex);
                AppendLog(logPath, "Installation failed: " + ex);
                ReliableDownloader.SafeDelete(partPath);
                SafeUi(delegate { screen = 3; Invalidate(); });
            }
        }

        private void OnDownloadProgress(int percent, long bytes, long total, double speed)
        {
            progressValue = percent;
            progressBytes = bytes;
            progressTotal = total;
            if (speed > 0) progressSpeed = speed;
            SafeInvalidate();
        }

        private void OnDownloadStatus(string value)
        {
            if (value == "mirror")
            {
                liveStatus = "mirror";
                AddUiLog(T("mirror"));
            }
            else if (value == "verify")
            {
                liveStatus = "verify";
                AddUiLog(T("verify"));
            }
            else if (value.StartsWith("retry:"))
            {
                liveStatus = "download";
                AddUiLog(T("retrying") + " " + value.Substring(6));
            }
            SafeInvalidate();
        }

        private void AddUiLog(string value)
        {
            lock (logTail)
            {
                logTail.Add("[" + DateTime.Now.ToString("HH:mm:ss") + "] " + value);
                if (logTail.Count > 30) logTail.RemoveAt(0);
            }
            SafeInvalidate();
        }

        private void CancelInstall()
        {
            if (!installing) return;
            cancelled = true;
            if (downloader != null) downloader.Cancel();
        }

        private void OpenLog()
        {
            try
            {
                if (!File.Exists(logPath)) File.WriteAllText(logPath, "", Encoding.UTF8);
                Process.Start(new ProcessStartInfo(logPath) { UseShellExecute = true });
            }
            catch (Exception ex) { AppendLog(logPath, "Could not open log: " + ex); }
        }

        private void LaunchInstalled()
        {
            string exe = Path.Combine(installPathBox.Text, "Flux Tasks.exe");
            try
            {
                if (File.Exists(exe)) Process.Start(new ProcessStartInfo(exe) { UseShellExecute = true });
            }
            catch (Exception ex) { AppendLog(logPath, "Could not launch app: " + ex); }
        }

        private void CreateShortcut(string installDir)
        {
            try
            {
                string shortcutPath = Path.Combine(
                    Environment.GetFolderPath(Environment.SpecialFolder.DesktopDirectory),
                    "Flux Tasks.lnk");
                Type shellType = Type.GetTypeFromProgID("WScript.Shell");
                dynamic shell = Activator.CreateInstance(shellType);
                dynamic link = shell.CreateShortcut(shortcutPath);
                link.TargetPath = Path.Combine(installDir, "Flux Tasks.exe");
                link.WorkingDirectory = installDir;
                link.Save();
                AppendLog(logPath, "Desktop shortcut created: " + shortcutPath);
            }
            catch (Exception ex) { AppendLog(logPath, "Shortcut creation failed: " + ex); }
        }

        private string ClassifyError(Exception ex)
        {
            string value = ex.ToString().ToLowerInvariant();
            if (value.Contains("sha256") || value.Contains("checksum")) return "hash";
            if (value.Contains("config")) return "config";
            if (value.Contains("cancel")) return "cancel";
            if (value.Contains("webexception") || value.Contains("connection") ||
                value.Contains("соединение") || value.Contains("timeout") ||
                value.Contains("http")) return "network";
            return "generic";
        }

        private string ErrorDescription()
        {
            if (friendlyError == "network") return T("networkError");
            if (friendlyError == "hash") return T("hashError");
            if (friendlyError == "config") return T("configError");
            return T("genericError");
        }

        private int StageIndex()
        {
            if (liveStatus == "prepare") return 0;
            if (liveStatus == "download" || liveStatus == "mirror") return 1;
            if (liveStatus == "verify") return 2;
            if (liveStatus == "unpack") return 3;
            return 4;
        }

        private string CurrentStage()
        {
            if (liveStatus == "mirror") return T("mirror");
            if (liveStatus == "download") return T("download");
            if (liveStatus == "verify") return T("verify");
            if (liveStatus == "unpack") return T("unpack");
            if (liveStatus == "finish") return T("finish");
            return T("prepare");
        }

        private static string FormatSize(long bytes)
        {
            if (bytes < 0) return "—";
            if (bytes >= 1024L * 1024L * 1024L) return (bytes / (1024d * 1024d * 1024d)).ToString("0.00") + " GB";
            if (bytes >= 1024L * 1024L) return (bytes / (1024d * 1024d)).ToString("0.0") + " MB";
            if (bytes >= 1024L) return (bytes / 1024d).ToString("0.0") + " KB";
            return bytes + " B";
        }

        private static string FormatSpeed(double bytes)
        {
            return bytes <= 0 ? "—" : FormatSize((long)bytes) + "/s";
        }

        private void SafeInvalidate()
        {
            SafeUi(delegate { Invalidate(); });
        }

        private void SafeUi(MethodInvoker action)
        {
            if (IsDisposed || !IsHandleCreated) return;
            try
            {
                if (InvokeRequired) BeginInvoke(action);
                else action();
            }
            catch { }
        }

        protected override void OnFormClosing(FormClosingEventArgs e)
        {
            if (installing)
            {
                CancelInstall();
                e.Cancel = true;
                return;
            }
            base.OnFormClosing(e);
        }

