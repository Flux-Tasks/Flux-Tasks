            {
                g.InterpolationMode = InterpolationMode.HighQualityBicubic;
                g.DrawImage(logo, new Rectangle(34, 24, 28, 28));
            }
            DrawText(g, "Flux Tasks", fBrand, text, new Rectangle(72, 25, 180, 28), TextFormatFlags.Left);

            FillRound(g, langRect, 10, Color.FromArgb(110, 10, 18, 35));
            DrawRound(g, langRect, 10, border, 1);
            int width = langRect.Width / 3;
            Rectangle active = new Rectangle(langRect.X + language * width + 3, langRect.Y + 3, width - 6, 26);
            FillGradient(g, active, 8, blue, purple);
            string[] langs = { "RU", "UA", "EN" };
            for (int i = 0; i < 3; i++)
            {
                Rectangle r = new Rectangle(langRect.X + i * width, langRect.Y, width, langRect.Height);
                DrawText(g, langs[i], fSmall, i == language ? Color.White : muted, r, TextFormatFlags.HorizontalCenter);
