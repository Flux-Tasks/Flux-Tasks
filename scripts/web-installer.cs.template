                "Flux Tasks could not be installed","The connection was interrupted while downloading installation files.",
                "Integrity verification failed. The downloaded file was removed.",
                "The installer configuration is missing or invalid.",
                "An error occurred during installation. Technical details are available below.","Details",
                "No technical details are available.","Retry","Flux Tasks was installed successfully",
                "Launch Flux Tasks","Done"
            }
        };
    }

    internal static class Program
    {
        [DllImport("shcore.dll")]
        private static extern int SetProcessDpiAwareness(int awareness);

        [DllImport("user32.dll")]
        private static extern bool SetProcessDPIAware();

        [STAThread]
        private static void Main(string[] args)
        {
            try { SetProcessDpiAwareness(2); }
            catch { try { SetProcessDPIAware(); } catch { } }
            ServicePointManager.SecurityProtocol = SecurityProtocolType.Tls12;
            if (args.Length >= 3 && args[0] == "--download-only")
            {
                try
                {
                    InstallerConfig testConfig = InstallerConfig.Load(args[1]);
                    string outputDir = args[2];
                    Directory.CreateDirectory(outputDir);
                    string testLog = Path.Combine(outputDir, "download-test.log");
                    string testPart = Path.Combine(outputDir, testConfig.FileName + ".part");
                    string testFinal = Path.Combine(outputDir, testConfig.FileName);
                    ReliableDownloader testDownloader = new ReliableDownloader(
                        testConfig, testLog,
                        delegate(int p, long b, long t, double s) { },
                        delegate(string value) { InstallerForm.AppendLog(testLog, "Status: " + value); });
                    testDownloader.Download(testPart, testFinal);
                    Environment.ExitCode = 0;
                }
                catch (Exception ex)
                {
                    try
                    {
                        string outputDir = args.Length >= 3 ? args[2] : AppDomain.CurrentDomain.BaseDirectory;
                        InstallerForm.AppendLog(Path.Combine(outputDir, "download-test.log"), "Self-test error: " + ex);
                    }
                    catch { }
                    Environment.ExitCode = 1;
                }
                return;
            }
            Application.EnableVisualStyles();
            Application.SetCompatibleTextRenderingDefault(false);
            InstallerForm form = new InstallerForm();
            if (args.Length >= 2 && args[0] == "--render-preview")
            {
                int previewScreen;
                if (args.Length >= 3 && Int32.TryParse(args[2], out previewScreen))
                    form.SetPreviewScreen(previewScreen);
                form.Show();
                Application.DoEvents();
                using (Bitmap bitmap = new Bitmap(form.Width, form.Height))
                {
                    form.DrawToBitmap(bitmap, new Rectangle(0, 0, bitmap.Width, bitmap.Height));
                    bitmap.Save(args[1], System.Drawing.Imaging.ImageFormat.Png);
                }
                form.Close();
                return;
            }
            Application.Run(form);
        }
    }
}
