        private static Bitmap TrimTransparent(Bitmap source)
        {
            int left = source.Width;
            int top = source.Height;
            int right = -1;
            int bottom = -1;
            for (int y = 0; y < source.Height; y++)
            {
                for (int x = 0; x < source.Width; x++)
                {
                    if (source.GetPixel(x, y).A < 12) continue;
                    if (x < left) left = x;
                    if (x > right) right = x;
                    if (y < top) top = y;
                    if (y > bottom) bottom = y;
                }
            }
            if (right < left || bottom < top) return source;
            Rectangle crop = Rectangle.FromLTRB(left, top, right + 1, bottom + 1);
            Bitmap result = new Bitmap(crop.Width, crop.Height);
            using (Graphics g = Graphics.FromImage(result))
                g.DrawImage(source, new Rectangle(0, 0, result.Width, result.Height), crop, GraphicsUnit.Pixel);
            source.Dispose();
            return result;
        }

        private void LoadConfig()
        {
            string path = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "installer-config.json");
            try
            {
                config = InstallerConfig.Load(path);
                installedVersion = config.Version;
                string downloadDir = Path.Combine(appRoot, "downloads");
                partPath = Path.Combine(downloadDir, config.FileName + ".part");
                finalPath = Path.Combine(downloadDir, config.FileName);
            }
            catch (Exception ex)
            {
                config = new InstallerConfig();
                technicalError = ex.ToString();
                friendlyError = "config";
                screen = 3;
                AppendLog(logPath, "Config error: " + ex);
            }
        }

        private void LoadLanguage()
        {
            string langPath = Path.Combine(appRoot, "language.txt");
            try
            {
                string saved = File.Exists(langPath) ? File.ReadAllText(langPath).Trim() : "";
                language = saved == "uk" ? 1 : saved == "en" ? 2 : 0;
            }
            catch { language = 0; }
        }

        private void SaveLanguage()
        {
            try
            {
                File.WriteAllText(
                    Path.Combine(appRoot, "language.txt"),
                    language == 1 ? "uk" : language == 2 ? "en" : "ru");
            }
            catch { }
        }

        private void AppendStartupLog()
        {
            AppendLog(logPath, "==================================================");
            AppendLog(logPath, "Installer version: " + (config == null ? "unknown" : config.Version));
            AppendLog(logPath, "OS version: " + Environment.OSVersion);
            AppendLog(logPath, "64-bit OS: " + Environment.Is64BitOperatingSystem);
            if (config != null)
            {
                AppendLog(logPath, "Download URL: " + config.PrimaryUrl);
                AppendLog(logPath, "Mirror URL: " + config.MirrorUrl);
            }
        }

        public static void AppendLog(string path, string message)
        {
            try
            {
                Directory.CreateDirectory(Path.GetDirectoryName(path));
                File.AppendAllText(
                    path,
                    "[" + DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss.fff") + "] " +
                    message + Environment.NewLine,
                    Encoding.UTF8);
            }
            catch { }
        }

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            Graphics g = e.Graphics;
            g.SmoothingMode = SmoothingMode.AntiAlias;
            g.PixelOffsetMode = PixelOffsetMode.HighQuality;
            hits.Clear();

            using (LinearGradientBrush background = new LinearGradientBrush(ClientRectangle, bg0, bg1, 35f))
                g.FillRectangle(background, ClientRectangle);
            DrawGlow(g, new Point(110, 90), 330, Color.FromArgb(50, 6, 182, 212));
            DrawGlow(g, new Point(810, 560), 380, Color.FromArgb(48, 124, 58, 237));
            DrawGlow(g, new Point(760, 70), 250, Color.FromArgb(28, 59, 130, 246));

            Rectangle shell = new Rectangle(12, 12, 896, 626);
            FillRound(g, shell, 24, card);
            DrawRound(g, shell, 24, border, 1);
            DrawHeader(g);

            if (screen == 0) DrawWelcome(g);
            else if (screen == 1) DrawOptions(g);
            else if (screen == 2) DrawProgress(g);
            else if (screen == 3) DrawError(g);
            else DrawSuccess(g);
        }

        private void DrawHeader(Graphics g)
