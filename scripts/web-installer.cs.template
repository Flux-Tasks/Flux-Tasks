    internal sealed class InstallerConfig
    {
        public string Version = "1.1.20";
        public string PrimaryUrl = "";
        public string MirrorUrl = "";
        public string ExpectedSha256 = "";
        public string FileName = "FluxTasks-Setup.exe";

        public static InstallerConfig Load(string path)
        {
            if (!File.Exists(path))
                throw new FileNotFoundException("installer-config.json was not found.", path);

            string json = File.ReadAllText(path, Encoding.UTF8);
            InstallerConfig config = new InstallerConfig();
            config.Version = Read(json, "version", true);
            config.PrimaryUrl = Read(json, "primaryUrl", true);
            config.MirrorUrl = Read(json, "mirrorUrl", false);
            config.ExpectedSha256 = Read(json, "expectedSha256", true).Trim().ToLowerInvariant();
            config.FileName = Read(json, "fileName", true);

            if (!Regex.IsMatch(config.ExpectedSha256, "^[a-f0-9]{64}$"))
                throw new InvalidDataException("expectedSha256 must contain exactly 64 hexadecimal characters.");
            if (!Uri.IsWellFormedUriString(config.PrimaryUrl, UriKind.Absolute))
                throw new InvalidDataException("primaryUrl must be an absolute URL.");
            if (!String.IsNullOrWhiteSpace(config.MirrorUrl) &&
                !Uri.IsWellFormedUriString(config.MirrorUrl, UriKind.Absolute))
                throw new InvalidDataException("mirrorUrl must be an absolute URL.");
            if (Path.GetFileName(config.FileName) != config.FileName)
                throw new InvalidDataException("fileName must not contain a path.");

            return config;
        }

        private static string Read(string json, string key, bool required)
        {
            Match match = Regex.Match(
                json,
                "\"" + Regex.Escape(key) + "\"\\s*:\\s*\"((?:\\\\.|[^\"])*)\"",
                RegexOptions.IgnoreCase);
            if (!match.Success)
            {
                if (required) throw new InvalidDataException("Missing config field: " + key);
                return "";
            }
            return Regex.Unescape(match.Groups[1].Value);
        }
    }

    internal sealed class DownloadResult
    {
        public string Path;
        public long Bytes;
        public long ExpectedBytes;
        public string Sha256;
    }

    internal sealed class ReliableDownloader
    {
        private readonly InstallerConfig config;
        private readonly string logPath;
        private readonly Action<int, long, long, double> progress;
        private readonly Action<string> status;
        private volatile bool cancelled;
        private HttpWebRequest activeRequest;

        public ReliableDownloader(
            InstallerConfig config,
            string logPath,
            Action<int, long, long, double> progress,
            Action<string> status)
        {
            this.config = config;
            this.logPath = logPath;
            this.progress = progress;
            this.status = status;
        }

        public void Cancel()
        {
            cancelled = true;
            HttpWebRequest request = activeRequest;
            if (request != null)
            {
                try { request.Abort(); } catch { }
            }
        }

        public DownloadResult Download(string partPath, string finalPath)
        {
            Exception primaryError = null;
            try
            {
                return DownloadFromSource(config.PrimaryUrl, partPath, finalPath, false);
            }
            catch (OperationCanceledException) { throw; }
            catch (Exception ex)
            {
                primaryError = ex;
                Log("Primary source failed after retries: " + ex);
            }

            if (!String.IsNullOrWhiteSpace(config.MirrorUrl))
            {
                status("mirror");
                Log("Primary server unavailable; switching to mirror URL: " + config.MirrorUrl);
                try
                {
                    return DownloadFromSource(config.MirrorUrl, partPath, finalPath, true);
                }
                catch (OperationCanceledException) { throw; }
                catch (Exception mirrorError)
                {
                    throw new IOException(
                        "Primary and mirror downloads failed. Primary: " +
                        primaryError.Message + " Mirror: " + mirrorError.Message,
                        mirrorError);
                }
            }

            throw primaryError;
        }

        private DownloadResult DownloadFromSource(
            string url,
            string partPath,
            string finalPath,
            bool mirror)
        {
            int[] delays = new int[] { 1000, 3000, 7000 };
            Exception lastError = null;

            for (int attempt = 1; attempt <= 3; attempt++)
            {
                ThrowIfCancelled();
                Log("Download URL: " + url);
                Log("Retry attempt: " + attempt + "/3" + (mirror ? " (mirror)" : " (primary)"));
                try
                {
                    DownloadResult result = DownloadAttempt(url, partPath);
                    VerifyAndCommit(result, partPath, finalPath);
                    result.Path = finalPath;
                    Log("Final installer path: " + finalPath);
                    return result;
                }
                catch (OperationCanceledException) { throw; }
                catch (Exception ex)
                {
                    lastError = ex;
                    Log("Attempt failed: " + ex);
                    activeRequest = null;
                    if (attempt < 3)
                    {
                        status("retry:" + attempt);
                        SleepCancelable(delays[attempt - 1]);
                    }
                }
            }

            throw lastError ?? new IOException("Download failed.");
        }

        private DownloadResult DownloadAttempt(string url, string partPath)
        {
            Directory.CreateDirectory(Path.GetDirectoryName(partPath));
            long existingBytes = File.Exists(partPath) ? new FileInfo(partPath).Length : 0;
            bool requestedResume = existingBytes > 0;

            HttpWebRequest request = (HttpWebRequest)WebRequest.Create(url);
            activeRequest = request;
            request.Method = "GET";
            request.UserAgent = "FluxTasksInstaller/" + config.Version;
            request.AllowAutoRedirect = true;
            request.MaximumAutomaticRedirections = 10;
            request.Timeout = 15000;
            request.ReadWriteTimeout = 30000;
            request.KeepAlive = true;
            request.AutomaticDecompression = DecompressionMethods.GZip | DecompressionMethods.Deflate;
            if (requestedResume) request.AddRange(existingBytes);

            DateTime started = DateTime.UtcNow;
            long lastBytes = existingBytes;
            DateTime lastSpeedAt = started;

            using (HttpWebResponse response = (HttpWebResponse)request.GetResponse())
            {
                int statusCode = (int)response.StatusCode;
                Log("HTTP status: " + statusCode + " " + response.StatusDescription);
                Log("Final response URL: " + response.ResponseUri);
                Log("Content-Type: " + (response.ContentType ?? "unknown"));
                Log("Content-Length: " + response.ContentLength);
                Log("Accept-Ranges: " + (response.Headers["Accept-Ranges"] ?? "not provided"));

                if (statusCode < 200 || statusCode >= 300)
                    throw new WebException("Unexpected HTTP status: " + statusCode);
                ValidateContentType(response.ContentType);

                bool resumed = requestedResume && statusCode == (int)HttpStatusCode.PartialContent;
                if (requestedResume && !resumed)
                {
                    Log("Server did not honor Range; restarting from byte 0.");
                    existingBytes = 0;
                }

                long expectedTotal = ResolveExpectedTotal(response, existingBytes, resumed);
                FileMode mode = resumed ? FileMode.Append : FileMode.Create;
                long downloaded = existingBytes;

                using (Stream input = response.GetResponseStream())
                using (FileStream output = new FileStream(partPath, mode, FileAccess.Write, FileShare.None, 1024 * 128))
                {
                    byte[] buffer = new byte[1024 * 128];
                    while (true)
                    {
                        ThrowIfCancelled();
                        int read = input.Read(buffer, 0, buffer.Length);
                        if (read <= 0) break;
                        output.Write(buffer, 0, read);
                        downloaded += read;

                        DateTime now = DateTime.UtcNow;
                        double elapsed = (now - lastSpeedAt).TotalSeconds;
                        double speed = 0;
                        if (elapsed >= 0.35)
                        {
                            speed = (downloaded - lastBytes) / elapsed;
                            lastBytes = downloaded;
                            lastSpeedAt = now;
                        }
                        int percent = expectedTotal > 0
                            ? (int)Math.Min(100, (downloaded * 100L) / expectedTotal)
                            : 0;
                        progress(percent, downloaded, expectedTotal, speed);
                    }
                    output.Flush(true);
                }

                Log("Downloaded bytes: " + downloaded);
                if (downloaded <= 0)
                    throw new InvalidDataException("Downloaded file is empty.");
                if (expectedTotal > 0 && downloaded != expectedTotal)
                    throw new InvalidDataException(
                        "Download incomplete: " + downloaded + "/" + expectedTotal + " bytes.");

                return new DownloadResult
                {
                    Path = partPath,
                    Bytes = downloaded,
                    ExpectedBytes = expectedTotal
                };
            }
        }

        private static long ResolveExpectedTotal(HttpWebResponse response, long existing, bool resumed)
        {
            if (resumed)
            {
                string range = response.Headers["Content-Range"];
                if (!String.IsNullOrWhiteSpace(range))
                {
                    Match match = Regex.Match(range, "/(\\d+)$");
                    long total;
                    if (match.Success && Int64.TryParse(match.Groups[1].Value, out total))
                        return total;
                }
                return response.ContentLength >= 0 ? existing + response.ContentLength : -1;
            }
            return response.ContentLength;
        }

        private static void ValidateContentType(string contentType)
        {
            string value = (contentType ?? "").ToLowerInvariant();
            if (value.Contains("text/html") ||
                value.Contains("application/json") ||
                value.Contains("text/plain"))
                throw new InvalidDataException(
                    "The download URL returned " + contentType + " instead of an installer file.");
        }

        private void VerifyAndCommit(DownloadResult result, string partPath, string finalPath)
        {
            status("verify");
            string actual;
            using (SHA256 sha = SHA256.Create())
            using (FileStream stream = File.OpenRead(partPath))
            {
                actual = BitConverter.ToString(sha.ComputeHash(stream))
                    .Replace("-", "").ToLowerInvariant();
            }
            result.Sha256 = actual;
            bool matches = String.Equals(actual, config.ExpectedSha256, StringComparison.OrdinalIgnoreCase);
            Log("SHA256 expected: " + config.ExpectedSha256);
            Log("SHA256 actual: " + actual);
            Log("SHA256 result: " + (matches ? "match" : "mismatch"));
            if (!matches)
            {
                SafeDelete(partPath);
                throw new InvalidDataException("SHA256 verification failed.");
            }

            SafeDelete(finalPath);
            File.Move(partPath, finalPath);
        }

        private void SleepCancelable(int milliseconds)
        {
            int elapsed = 0;
            while (elapsed < milliseconds)
            {
                ThrowIfCancelled();
                Thread.Sleep(Math.Min(100, milliseconds - elapsed));
                elapsed += 100;
            }
        }

        private void ThrowIfCancelled()
        {
            if (cancelled) throw new OperationCanceledException("Download cancelled.");
        }

        private void Log(string message)
        {
            InstallerForm.AppendLog(logPath, message);
        }

        public static void SafeDelete(string path)
        {
            try { if (!String.IsNullOrWhiteSpace(path) && File.Exists(path)) File.Delete(path); }
            catch { }
        }
    }

