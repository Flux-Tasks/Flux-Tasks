            else
                using (Pen p = new Pen(text, 2))
                {
                    g.DrawLine(p, r.X + 9, r.Y + 9, r.Right - 9, r.Bottom - 9);
                    g.DrawLine(p, r.Right - 9, r.Y + 9, r.X + 9, r.Bottom - 9);
                }
            hits[kind] = r;
        }

